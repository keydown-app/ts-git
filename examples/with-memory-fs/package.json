{
  "name": "@ts-git/example-with-memory-fs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:ci": "npm run build && (npm run preview -- --port 4173 & PREVIEW_PID=$!; sleep 3; npm run test:e2e; TEST_EXIT=$?; kill $PREVIEW_PID 2>/dev/null; exit $TEST_EXIT)"
  },
  "dependencies": {
    "@keydown-app/ts-git": "workspace:*",
    "@ts-git/ui": "workspace:*",
    "lucide": "^0.577.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
