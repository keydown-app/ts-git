---
import Default from '@astrojs/starlight/components/Sidebar.astro';
---

<div class="sidebar-banner">
  <div class="alpha-banner-card">
    <strong>⚠️ Alpha Release</strong>
    <p>TS-Git is work in progress and currently only supports a local subset of Git commands.</p>
    <a href="/roadmap">View roadmap and limitations →</a>
  </div>
</div>

<Default {...Astro.props}>
  <slot />
</Default>

<style>
  .sidebar-banner {
    padding: 0 0.5em;
    margin-bottom: 0.5rem;
  }
  
  .alpha-banner-card {
    background: var(--sl-color-orange-low);
    border: 1px solid var(--sl-color-orange);
    border-radius: 0.5rem;
    padding: 0.75rem;
    font-size: var(--sl-text-xs);
  }
  
  .alpha-banner-card strong {
    color: var(--sl-color-orange-high);
    display: block;
    margin-bottom: 0.25rem;
  }
  
  .alpha-banner-card p {
    color: var(--sl-color-text);
    margin: 0 0 0.5rem 0;
    line-height: 1.4;
  }
  
  .alpha-banner-card a {
    color: var(--sl-color-orange-high);
    text-decoration: none;
    font-weight: 500;
  }
  
  .alpha-banner-card a:hover {
    text-decoration: underline;
  }
  
  :root[data-theme='light'] .alpha-banner-card {
    background: #fff7ed;
    border-color: #f97316;
  }
  
  :root[data-theme='light'] .alpha-banner-card strong,
  :root[data-theme='light'] .alpha-banner-card a {
    color: #c2410c;
  }
</style>
